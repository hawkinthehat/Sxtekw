<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>SXT’EKW | Neural Weaver</title>
    <link rel="apple-touch-icon" href="logo.png">
    <link rel="icon" type="image/png" sizes="512x512" href="logo.png">
    <style>
        :root { --bg: #020617; --teal: #2dd4bf; --text: #f1f5f9; --red: #f43f5e; --card: #1e293b; --gold: #fbbf24; --cedar: #78350f; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none; }
        body { background: var(--bg); color: var(--text); font-family: -apple-system, system-ui, sans-serif; margin: 0; overflow: hidden; touch-action: none; text-align: center; height: 100vh; }
        
        .screen { display: none; height: 100vh; width: 100vw; flex-direction: column; justify-content: center; align-items: center; position: absolute; padding: 30px; z-index: 5; }
        .active { display: flex; animation: fadeIn 0.5s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes pulse {
            0% { transform: scaleX(1); opacity: 0.5; }
            50% { transform: scaleX(2); opacity: 1; }
            100% { transform: scaleX(1); opacity: 0.5; }
        }

        .btn { background: var(--teal); color: var(--bg); border: none; padding: 20px; border-radius: 18px; width: 100%; max-width: 360px; font-weight: 900; font-size: 1rem; margin: 8px 0; cursor: pointer; letter-spacing: 2px; text-transform: uppercase; z-index: 20; transition: 0.3s; }
        .btn:active { transform: scale(0.95); }
        .emergency { background: var(--red); color: white; box-shadow: 0 0 30px rgba(244, 63, 94, 0.4); }
        .gold-btn { background: var(--gold); color: var(--bg); border: 2px solid var(--cedar); }
        .secondary { background: none; border: 1px solid var(--cedar); color: var(--cedar); }
        
        .top-bar { position: absolute; top: 0; left: 0; width: 100%; padding: 20px; display: flex; justify-content: space-between; z-index: 1000; }
        .control-icon { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 50%; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; cursor: pointer; backdrop-filter: blur(5px); color: white; }

        canvas { position: absolute; top: 0; left: 0; z-index: 1; }
        #visual-msg { color: var(--teal); letter-spacing: 4px; z-index: 10; font-weight: 900; margin-top: 20px; text-shadow: 0 0 10px rgba(45, 212, 191, 0.5); }
        input { background: rgba(255,255,255,0.05); border: 1px solid var(--teal); color: white; padding: 18px; border-radius: 15px; width: 85%; text-align: center; margin: 25px 0; font-size: 1.2rem; }
    </style>
</head>
<body>

    <div id="ui-overlay" style="display: none;">
        <div class="top-bar">
            <div id="vol-btn" class="control-icon" onclick="toggleAudio()">🔊</div>
            <div class="control-icon" onclick="window.open('https://www.buymeacoffee.com/Hawkinthehat', '_blank')" style="color: var(--gold);">☕</div>
            <div class="control-icon" onclick="exitAll()" style="color: var(--red);">✕</div>
        </div>
    </div>

    <div id="home" class="screen active">
        <h1 style="color: var(--teal); letter-spacing: 10px; font-weight: 900; margin-bottom: 5px;">SXT’EKW</h1>
        <p style="opacity: 0.5; font-size: 0.7rem; margin-bottom: 30px; letter-spacing: 4px;">THE QUIET | NEURAL WEAVER</p>
        
        <button class="btn emergency" onclick="startProtocol()">SYSTEM RED: RESET</button>
        <button class="btn gold-btn" onclick="startWeave()">THE WEAVE (MEDITATION)</button>
        <button class="btn secondary" onclick="show('vantage')">The Vantage (Observe)</button>
        
        <div style="margin-top: 40px; opacity: 0.8; font-size: 0.75rem;">
            <p>Inspired by Coast Salish Resilience</p>
            <a href="https://www.buymeacoffee.com/Hawkinthehat" target="_blank" style="color: var(--gold); text-decoration: none; font-weight: bold;">Support the Founder ⚡</a>
        </div>
    </div>

    <div id="vantage" class="screen">
        <h2 style="color: var(--teal);">THE VANTAGE</h2>
        <p style="opacity: 0.8; max-width: 280px;">Label the thought. Observe it shatter. Re-weave the quiet.</p>
        <input type="text" id="thought-input" placeholder="Worry Name...">
        <button class="btn" onclick="initVantage()">BEGIN OBSERVATION</button>
        <button class="btn secondary" onclick="show('home')">BACK</button>
    </div>

    <div id="visual" class="screen">
        <canvas id="canvas"></canvas>
        <div id="logic-overlay" style="position: absolute; top: 25%; background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); padding: 25px; border-radius: 20px; border: 1px solid var(--teal); width: 80%; max-width: 400px; z-index: 20; display: none; opacity: 0; transition: opacity 1s ease;">
            <p style="color: var(--teal); font-size: 0.7rem; letter-spacing: 2px; margin-bottom: 10px;">NEURAL LOAD INITIATED</p>
            <h2 id="logic-text" style="color: white; margin: 0; font-size: 1.4rem;"></h2>
        </div>
        <h3 id="visual-msg" style="position: absolute; bottom: 15%; width: 100%;">CATCH THE CLICK</h3>
    </div>

    <div id="weave" class="screen">
        <canvas id="weave-canvas"></canvas>
        <div id="weave-instructions" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 80%; pointer-events: none; z-index: 100; transition: opacity 1.5s ease-out;">
            <h2 style="color: var(--teal); letter-spacing: 5px; margin-bottom: 10px;">THE WEAVE</h2>
            <p style="color: var(--gold); font-weight: bold; font-size: 0.9rem; line-height: 1.6;">
                DRAG YOUR THUMB ACROSS THE DOTS<br>
                <span style="opacity: 0.7; font-weight: normal;">Connect the synapses. Build the basket.<br>Restore the quiet.</span>
            </p>
            <div style="width: 40px; height: 2px; background: var(--teal); margin: 20px auto; animation: pulse 2s infinite;"></div>
        </div>
        <div style="position: absolute; top: 80px; pointer-events: none;">
            <h2 style="color: var(--gold); letter-spacing: 5px; margin: 0;">NEURAL WEAVER</h2>
            <p id="weave-progress" style="opacity: 0.6;">0% WOVEN</p>
        </div>
        <button class="btn secondary" style="position: absolute; bottom: 40px; width: 60%; border-color: rgba(255,255,255,0.2); z-index: 110;" onclick="exitAll()">EXIT TO CALM</button>
    </div>

    <div id="success" class="screen">
        <h1 style="color: var(--teal); letter-spacing: 4px;">SXT’EKW REACHED</h1>
        <p id="success-quote" style="max-width: 300px; line-height: 1.6;"></p>
        <button class="btn gold-btn" onclick="startWeave()">WEAVE THE QUIET (COOL DOWN)</button>
        <button class="btn secondary" onclick="window.open('https://www.buymeacoffee.com/Hawkinthehat', '_blank')">SUPPORT THE PROJECT ☕</button>
        <button class="btn secondary" onclick="show('home')">RETURN TO HOME</button>
    </div>

    <script>
        const canvas = document.getElementById('canvas');
        const ctx = canvas.getContext('2d');
        const weaveCanvas = document.getElementById('weave-canvas');
        const wCtx = weaveCanvas.getContext('2d');
        
        let particles = [], weavePoints = [], mouse = { x: null, y: null }, audioCtx, isMuted = false;
        let binauralGain, leftOsc, rightOsc, vantageMode = false, shatterPoint = false, weavingActive = false;
        
        // Pulse Sync Params
        let sparkX = 0, sparkDir = 1, sparkSpeed = 6;

        const logicTasks = ["Spell 'CALM' backwards", "What is 18 + 24?", "Name 3 PNW trees", "Count back from 20 by 4s"];

        function initAudio() {
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            if (audioCtx.state === 'suspended') audioCtx.resume();
        }

        function toggleAudio() {
            isMuted = !isMuted;
            document.getElementById('vol-btn').innerText = isMuted ? "🔇" : "🔊";
            if(binauralGain) binauralGain.gain.setTargetAtTime(isMuted ? 0 : 0.05, audioCtx.currentTime, 0.1);
        }

        function show(id) {
            initAudio();
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            document.getElementById('ui-overlay').style.display = (id === 'home' || id === 'success') ? 'none' : 'block';
            if (id === 'visual') startVisual();
        }

        async function startProtocol() {
            let tasksSolved = 0;
            let userReady = false;

            while (!userReady) {
                // Choose a random task type
                const type = Math.floor(Math.random() * 3);
                let challenge, answer;

                if (type === 0) { // MATH
                    const n1 = Math.floor(Math.random() * 15) + 10;
                    const n2 = Math.floor(Math.random() * 10) + 5;
                    challenge = `SYNC: What is ${n1} + ${n2}?`;
                    answer = (n1 + n2).toString();
                } else if (type === 1) { // LINGUISTIC
                    const words = ["HAWKS", "SALISH", "CEDAR", "RIVER", "SOUND"];
                    const word = words[Math.floor(Math.random() * words.length)];
                    challenge = `REVERSE: Spell '${word}' backwards:`;
                    answer = word.split('').reverse().join('').toUpperCase();
                } else { // SENSORY
                    challenge = "GROUNDING: Name a color you see right now:";
                    answer = "ANY"; // Accept any input for grounding
                }

                const input = prompt(`${challenge}\n\n(Solved: ${tasksSolved})\nType 'READY' if you feel the quiet.`);
                
                if (!input) return exitAll(); // Cancel if they hit cancel

                if (input.toUpperCase() === "READY" && tasksSolved >= 3) {
                    userReady = true;
                } else if (input.toUpperCase() === "READY" && tasksSolved < 3) {
                    alert("Neural lock not yet achieved. Complete a few more tasks first.");
                } else if (answer === "ANY" || input.toUpperCase() === answer) {
                    tasksSolved++;
                    if (navigator.vibrate) navigator.vibrate(20);
                } else {
                    alert("Sync interrupted. Focus on the next one.");
                }
            }

            if (navigator.vibrate) navigator.vibrate([50, 100, 50]);
            show('visual'); // Move to Pulse Sync (EMDR)
        }

        function initVantage() {
            vantageMode = true; shatterPoint = false;
            const thought = document.getElementById('thought-input').value || "Worry";
            show('visual');
            document.getElementById('visual-msg').innerText = `OBSERVE: ${thought.toUpperCase()}`;
            setTimeout(() => { 
                shatterPoint = true; 
                if (navigator.vibrate) navigator.vibrate([100, 50, 200]);
                document.getElementById('visual-msg').innerText = "SHATTERED. RECOVERY SUGGESTED.";
                setTimeout(() => triggerSuccess(), 5000);
            }, 12000);
        }

        function startWeave() {
            weavingActive = true;
            show('weave');

            // Reset the instruction overlay visibility
            const instr = document.getElementById('weave-instructions');
            instr.style.opacity = "1";

            // Start the fade-out after 3.5 seconds
            setTimeout(() => {
                instr.style.opacity = "0";
            }, 3500);

            weaveCanvas.width = window.innerWidth;
            weaveCanvas.height = window.innerHeight;
            weavePoints = [];

            const cols = 7, rows = 9; // Slightly fewer dots for better "touch" targets
            for(let i=0; i<cols; i++) {
                for(let j=0; j<rows; j++) {
                    weavePoints.push({
                        x: (weaveCanvas.width / (cols + 1)) * (i + 1),
                        y: (weaveCanvas.height / (rows + 1)) * (j + 1),
                        locked: false
                    });
                }
            }
            animateWeave();
        }

        function startVisual() {
            canvas.width = window.innerWidth; canvas.height = window.innerHeight;
            sparkX = canvas.width / 2;
            particles = []; for (let i = 0; i < 50; i++) particles.push(new Neuron());
            
            binauralGain = audioCtx.createGain();
            binauralGain.gain.setValueAtTime(0, audioCtx.currentTime);
            binauralGain.gain.linearRampToValueAtTime(isMuted ? 0 : 0.05, audioCtx.currentTime + 2);
            binauralGain.connect(audioCtx.destination);
            
            leftOsc = audioCtx.createOscillator(); rightOsc = audioCtx.createOscillator();
            leftOsc.frequency.value = 432; rightOsc.frequency.value = 442;
            leftOsc.connect(binauralGain); rightOsc.connect(binauralGain);
            leftOsc.start(); rightOsc.start();
            animate();
        }

        class Neuron {
            constructor() { this.x = Math.random()*canvas.width; this.y = Math.random()*canvas.height; this.sx = (Math.random()-0.5); this.sy = (Math.random()-0.5); }
            update() {
                this.x += this.sx; this.y += this.sy;
                if (mouse.x) {
                    let d = Math.sqrt((mouse.x-this.x)**2 + (mouse.y-this.y)**2);
                    if (d < 120) {
                        let f = (120-d)/120;
                        if(shatterPoint) { this.x -= (mouse.x-this.x)*f*0.5; this.y -= (mouse.y-this.y)*f*0.5; }
                    }
                }
                if (this.x > canvas.width || this.x < 0) this.sx *= -1;
                if (this.y > canvas.height || this.y < 0) this.sy *= -1;
            }
            draw() {
                ctx.fillStyle = shatterPoint ? "var(--gold)" : "var(--teal)";
                ctx.globalAlpha = 0.3; ctx.beginPath(); ctx.arc(this.x, this.y, 2, 0, Math.PI*2); ctx.fill();
            }
        }

        function animate() {
            if (!document.getElementById('visual').classList.contains('active')) return;
            ctx.fillStyle = 'rgba(2, 6, 23, 0.2)'; ctx.fillRect(0,0,canvas.width, canvas.height);
            
            if (!shatterPoint) {
                // PULSE SYNC ENGINE
                sparkX += sparkSpeed * sparkDir;
                if (sparkX >= canvas.width - 40 || sparkX <= 40) {
                    sparkDir *= -1;
                    if (navigator.vibrate) navigator.vibrate(30);
                    ctx.shadowBlur = 40; ctx.shadowColor = "var(--teal)";
                }
                ctx.fillStyle = "var(--teal)";
                ctx.beginPath(); ctx.arc(sparkX, canvas.height/2, 10, 0, Math.PI*2); ctx.fill();
                ctx.shadowBlur = 0;
            } else {
                particles.forEach(p => { p.update(); p.draw(); });
            }
            requestAnimationFrame(animate);
        }

        function animateWeave() {
            if (!weavingActive) return;
            wCtx.fillStyle = 'rgba(2, 6, 23, 0.4)'; wCtx.fillRect(0,0,weaveCanvas.width, weaveCanvas.height);
            
            let locked = 0;
            weavePoints.forEach(p => {
                // MAGNETIC SNAP: Increase the radius to 60 for easier "locking"
                let d = Math.sqrt((mouse.x-p.x)**2 + (mouse.y-p.y)**2);
                if (d < 60 && !p.locked) {
                    p.locked = true;
                    if(navigator.vibrate) navigator.vibrate(10);
                }
                
                if (p.locked) {
                    locked++;
                    wCtx.shadowBlur = 10; wCtx.shadowColor = "var(--gold)";
                    wCtx.fillStyle = "var(--gold)";
                    wCtx.beginPath(); wCtx.arc(p.x, p.y, 4, 0, Math.PI*2); wCtx.fill();
                    wCtx.shadowBlur = 0;

                    // DRAW CONNECTIONS
                    weavePoints.forEach(p2 => {
                        if(p2.locked && Math.sqrt((p2.x-p.x)**2 + (p2.y-p.y)**2) < 130) {
                            wCtx.strokeStyle = "rgba(251, 191, 36, 0.4)";
                            wCtx.lineWidth = 2;
                            wCtx.beginPath(); wCtx.moveTo(p.x, p.y); wCtx.lineTo(p2.x, p2.y); wCtx.stroke();
                        }
                    });
                } else {
                    // UNLOCKED DOTS: Make them slightly larger and pulse so they are visible
                    wCtx.fillStyle = "rgba(255,255,255,0.15)";
                    wCtx.beginPath(); wCtx.arc(p.x, p.y, 2, 0, Math.PI*2); wCtx.fill();
                }
            });
            
            let percent = Math.round(locked/weavePoints.length*100);
            document.getElementById('weave-progress').innerText = `${percent}% WOVEN`;
            
            if (percent > 95) {
                document.getElementById('weave-progress').innerText = "COMPLETE. YOU ARE CENTERED.";
            }
            
            requestAnimationFrame(animateWeave);
        }

        window.addEventListener('touchstart', e => { mouse.x = e.touches[0].clientX; mouse.y = e.touches[0].clientY; });
        window.addEventListener('touchmove', e => { mouse.x = e.touches[0].clientX; mouse.y = e.touches[0].clientY; });
        window.addEventListener('mousedown', e => { mouse.x = e.clientX; mouse.y = e.clientY; });

        // Emergency Double-Tap Exit
        let lastTap = 0;
        window.addEventListener('touchend', () => {
            const currentTime = new Date().getTime();
            const tapLength = currentTime - lastTap;
            if (tapLength < 300 && tapLength > 0) {
                // Double Tap Detected
                if (confirm("Exit to Home?")) {
                    exitAll();
                }
            }
            lastTap = currentTime;
        });

        function triggerSuccess() {
            exitAll(); document.getElementById('success-quote').innerText = "System neutralized. The signal is clear. Re-weave your quiet below.";
            show('success');
        }

        function exitAll() {
            // 1. Stop the Visual Loops
            weavingActive = false;
            vantageMode = false;
            shatterPoint = false;
            
            // 2. Kill the Audio
            if (leftOsc) {
                leftOsc.stop();
                rightOsc.stop();
                leftOsc = null;
                rightOsc = null;
            }
            
            // 3. Clear the Canvases
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            wCtx.clearRect(0, 0, weaveCanvas.width, weaveCanvas.height);
            
            // 4. Return to Home
            show('home');
            
            // 5. Final Haptic Confirmation
            if (navigator.vibrate) navigator.vibrate(50);
        }
    </script>
</body>
</html>
